# Application Configuration
NODE_ENV=development
PORT=8080
APP_NAME=Maximo Vendor Portal

# MAS API Configuration
# Configure these in the application UI or set them here
MAS_BASE_URL=https://your-maximo-server.com
MAS_API_KEY=your-api-key-here
MAS_TENANT_ID=
MAS_TIMEOUT=30000
MAS_REJECT_UNAUTHORIZED=false

# Database Configuration (if needed)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendor_portal
DB_USER=vendor_portal_user
DB_PASSWORD=change-this-password
DB_POOL_MIN=2
DB_POOL_MAX=10

# Security Configuration
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=24h
SESSION_SECRET=change-this-secret-in-production
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# CORS Configuration
CORS_ORIGIN=http://localhost:8080
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# OpenShift Configuration
OPENSHIFT_BUILD_NAME=
OPENSHIFT_BUILD_NAMESPACE=
OPENSHIFT_BUILD_COMMIT=